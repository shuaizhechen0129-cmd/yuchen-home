# 启用缓存
<IfModule mod_expires.c>
    ExpiresActive On

    # HTML - 禁用缓存
    <FilesMatch "\.html?$">
        ExpiresDefault "access plus 0 seconds"
    </FilesMatch>

    # CSS - 缓存1年
    <FilesMatch "\.css$">
        ExpiresDefault "access plus 1 year"
        Header append Cache-Control "public"
    </FilesMatch>

    # JavaScript - 缓存1年
    <FilesMatch "\.js$">
        ExpiresDefault "access plus 1 year"
        Header append Cache-Control "public"
    </FilesMatch>

    # 图片 - 缓存1年
    <FilesMatch "\.(jpe?g|png|gif|svg|webp)$">
        ExpiresDefault "access plus 1 year"
        Header append Cache-Control "public"
    </FilesMatch>

    # 字体 - 缓存1年
    <FilesMatch "\.(woff|woff2|ttf|eot)$">
        ExpiresDefault "access plus 1 year"
        Header append Cache-Control "public"
    </FilesMatch>
</IfModule>

# 压缩文本文件
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/plain
    AddOutputFilterByType DEFLATE text/html
    AddOutputFilterByType DEFLATE text/xml
    AddOutputFilterByType DEFLATE text/css
    AddOutputFilterByType DEFLATE application/xml
    AddOutputFilterByType DEFLATE application/xhtml+xml
    AddOutputFilterByType DEFLATE application/rss+xml
    AddOutputFilterByType DEFLATE application/javascript
    AddOutputFilterByType DEFLATE application/x-javascript
</IfModule>

# 设置MIME类型
<IfModule mod_mime.c>
    AddType application/x-font-woff2 .woff2
    AddType application/vnd.ms-fontobject .eot
    AddType font/woff2 .woff2
    AddType font/woff .woff
</IfModule>

# 禁用ETag
FileETag None

# 启用Keep-Alive
<IfModule mod_headers.c>
    Header set Connection "keep-alive"

    # 安全头
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set X-XSS-Protection "1; mode=block"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"

    # Content-Security-Policy
    Header set Content-Security-Policy "default-src 'self'; img-src 'self' data: https://*.gravatar.com; script-src 'self' 'unsafe-inline' 'unsafe-eval'; style-src 'self' 'unsafe-inline'; font-src 'self' data:; connect-src 'self' https://*.google-analytics.com;"

    # 强制HTTPS
    # RewriteCond %{HTTPS} off
    # RewriteRule (.*) https://%{HTTP_HOST}%{REQUEST_URI}

    # 防止点击劫持
    Header always set X-Frame-Options "SAMEORIGIN"

    # 防止MIME类型混淆攻击
    Header always set X-Content-Type-Options "nosniff"

    # 启用HSTS（如果使用HTTPS）
    # Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains"
</IfModule>

# 启用目录列表禁用
Options -Indexes

# 错误页面设置
ErrorDocument 404 /404.html

# 防止访问敏感文件
<FilesMatch "^\.">
    Require all denied
</FilesMatch>

<FilesMatch "\.(log|conf|ini)$">
    Require all denied
</FilesMatch>

# 防止隐藏文件暴露
<FilesMatch "^\.(htaccess|htpasswd|error\.log|access\.log)">
    Require all denied
</FilesMatch>